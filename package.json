{
  "name": "financeapp",
  "private": true,
  "version": "1.0.0",
  "description": "Tooling for formatting and CI checks",
  "scripts": {
    "dev": "live-server",
    "sanity": "node scripts/sanity-check.mjs",
    "format": "prettier --write \"*.md\" \"docs/**/*.md\" \"*.json\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"*.md\" \"docs/**/*.md\" \"*.json\" \".github/**/*.yml\"",
    "validate:syntax": "node scripts/validate-syntax.mjs",
    "lint": "npm run format:check && npm run validate:syntax",
    "test": "npm run sanity && npm run validate:syntax && npm run validate:gas-runtime && npm run test:behavioral",
    "hooks:install": "git config core.hooksPath .githooks",
    "check:merge-conflicts": "node scripts/check-merge-conflicts.mjs",
    "test:behavioral": "node scripts/run-behavioral-tests.mjs",
    "validate:gas-runtime": "node scripts/validate-gas-runtime.mjs"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "prettier": "^3.6.2"
  }
}
