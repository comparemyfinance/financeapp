{
  "name": "financeapp",
  "private": true,
  "version": "1.0.0",
  "description": "Tooling for formatting and CI checks",
  "scripts": {
    "sanity": "test -f Code.gs && test -f Index.html && test -f appsscript.json",
    "format": "prettier --write \"*.md\" \"docs/**/*.md\" \"*.json\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"*.md\" \"docs/**/*.md\" \"*.json\" \".github/**/*.yml\"",
    "lint": "npm run format:check",
    "test": "npm run sanity",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
