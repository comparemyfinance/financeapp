#!/usr/bin/env bash

set -euo pipefail

if [ -n "${CI:-}" ]; then
  exit 0
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "[post-merge] npm is required but was not found on PATH. Install Node.js/npm and run checks manually."
  exit 1
fi

echo "[post-merge] Running merge safety checks..."
npm run lint
npm run format:check
